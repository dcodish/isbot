# Copy to .env (same folder) and fill in. The .env file is gitignored but
# still travels between your machines via Dropbox, which is intentional.

SSH_HOST=themathbible.com
SSH_PORT=22
SSH_USER=root
# Leave empty to let paramiko/ssh-agent find the key; otherwise give an
# absolute path (Windows: forward slashes or double-backslashes work).
SSH_KEY_PATH=

# DB host is relative to the prod server (MySQL listens on localhost there).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=isbot_ro
DB_PASSWORD=REPLACE_ME
DB_NAME=isquestions_gamified
